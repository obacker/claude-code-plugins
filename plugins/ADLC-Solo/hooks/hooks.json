{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-spec.py",
            "timeout": 5,
            "statusMessage": "Checking spec protection..."
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enforce-worktree.py",
            "timeout": 5,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-edit-compile-check.py",
            "timeout": 15,
            "statusMessage": "Running compile check..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on-agent-stop.sh",
            "timeout": 10,
            "statusMessage": "Validating agent work..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/save-context.sh",
            "timeout": 10,
            "statusMessage": "Saving context snapshot..."
          }
        ]
      }
    ]
  }
}
