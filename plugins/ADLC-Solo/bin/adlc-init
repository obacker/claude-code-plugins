#!/usr/bin/env bash
# ============================================================================
# adlc-init — Initialize ADLC v13 for a project
#
# Copies scaffold templates, detects project stack, generates starter
# verification.yml with detected commands. Run once per project.
#
# Usage: adlc-init [--force]
#   --force: overwrite existing files (default: skip existing)
# ============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"
SCAFFOLD_DIR="$PLUGIN_ROOT/scaffold"
FORCE=false

# Parse args
for arg in "$@"; do
    case $arg in
        --force) FORCE=true ;;
        --help|-h)
            echo "Usage: adlc-init [--force]"
            echo "Initialize ADLC v13 scaffold for the current project."
            echo ""
            echo "Options:"
            echo "  --force    Overwrite existing scaffold files"
            echo "  --help     Show this help"
            exit 0
            ;;
    esac
done

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}ADLC v13 — Project Initialization${NC}"
echo "=================================="
echo ""

# --- Detect project info ---
PROJECT_NAME=$(basename "$(pwd)")
echo -e "Project: ${GREEN}$PROJECT_NAME${NC}"

# --- Detect stack ---
STACK="unknown"
BUILD_CMD=""
LINT_CMD=""
TEST_CMD=""
DEV_CMD=""
DEPS_CHECK=""
TYPECHECK_CMD=""

if [[ -f "package.json" ]]; then
    # Node.js project
    if [[ -f "tsconfig.json" ]]; then
        STACK="TypeScript / Node.js"
        TYPECHECK_CMD="npx tsc --noEmit"
    else
        STACK="JavaScript / Node.js"
        TYPECHECK_CMD="echo 'no type checking configured'"
    fi

    # Detect framework
    if grep -q '"next"' package.json 2>/dev/null; then
        STACK="$STACK / Next.js"
        BUILD_CMD="npm run build"
        DEV_CMD="npm run dev"
    elif grep -q '"nuxt"' package.json 2>/dev/null; then
        STACK="$STACK / Nuxt"
        BUILD_CMD="npm run build"
        DEV_CMD="npm run dev"
    elif grep -q '"express"' package.json 2>/dev/null; then
        STACK="$STACK / Express"
        BUILD_CMD="npm run build"
        DEV_CMD="npm run dev"
    fi

    # Detect test runner
    if grep -q '"vitest"' package.json 2>/dev/null; then
        TEST_CMD="npx vitest run"
    elif grep -q '"jest"' package.json 2>/dev/null; then
        TEST_CMD="npx jest"
    elif grep -q '"mocha"' package.json 2>/dev/null; then
        TEST_CMD="npx mocha"
    else
        TEST_CMD="npm test"
    fi

    # Detect linter
    if grep -q '"eslint"' package.json 2>/dev/null; then
        LINT_CMD="npx eslint ."
    elif grep -q '"biome"' package.json 2>/dev/null; then
        LINT_CMD="npx biome check ."
    else
        LINT_CMD="echo 'no linter configured'"
    fi

    BUILD_CMD="${BUILD_CMD:-npm run build}"
    DEV_CMD="${DEV_CMD:-npm run dev}"
    DEPS_CHECK="npm ci --silent"

elif [[ -f "go.mod" ]]; then
    STACK="Go"
    BUILD_CMD="go build ./..."
    LINT_CMD="golangci-lint run"
    TEST_CMD="go test ./..."
    DEV_CMD="go run ."
    DEPS_CHECK="go mod download"
    TYPECHECK_CMD="go vet ./..."

    # Detect framework
    if grep -q "gin-gonic" go.mod 2>/dev/null; then
        STACK="Go / Gin"
    elif grep -q "labstack/echo" go.mod 2>/dev/null; then
        STACK="Go / Echo"
    elif grep -q "gofiber" go.mod 2>/dev/null; then
        STACK="Go / Fiber"
    fi

elif [[ -f "pyproject.toml" ]] || [[ -f "setup.py" ]] || [[ -f "requirements.txt" ]]; then
    STACK="Python"
    BUILD_CMD="echo 'no build step'"
    TEST_CMD="pytest"
    DEV_CMD="python -m uvicorn main:app --reload"
    DEPS_CHECK="pip install -r requirements.txt -q"
    TYPECHECK_CMD="mypy ."

    if [[ -f "pyproject.toml" ]]; then
        if grep -q "fastapi" pyproject.toml 2>/dev/null; then
            STACK="Python / FastAPI"
        elif grep -q "django" pyproject.toml 2>/dev/null; then
            STACK="Python / Django"
            TEST_CMD="python manage.py test"
            DEV_CMD="python manage.py runserver"
        elif grep -q "flask" pyproject.toml 2>/dev/null; then
            STACK="Python / Flask"
        fi
    fi

    # Detect linter
    if [[ -f "pyproject.toml" ]] && grep -q "ruff" pyproject.toml 2>/dev/null; then
        LINT_CMD="ruff check ."
    else
        LINT_CMD="flake8 ."
    fi

elif [[ -f "Cargo.toml" ]]; then
    STACK="Rust"
    BUILD_CMD="cargo build"
    LINT_CMD="cargo clippy -- -D warnings"
    TEST_CMD="cargo test"
    DEV_CMD="cargo run"
    DEPS_CHECK="cargo fetch"
    TYPECHECK_CMD="cargo check"
fi

echo -e "Detected stack: ${GREEN}$STACK${NC}"
echo ""

# --- Copy scaffold files ---
copy_file() {
    local src="$1"
    local dest="$2"
    local desc="$3"

    if [[ -f "$dest" ]] && [[ "$FORCE" == "false" ]]; then
        echo -e "  ${YELLOW}SKIP${NC} $desc (already exists)"
    else
        cp "$src" "$dest"
        echo -e "  ${GREEN}CREATE${NC} $desc"
    fi
}

# Create .sdlc directory
mkdir -p .sdlc/milestones

# Copy and customize scaffold files
echo "Scaffold files:"

# CLAUDE.md — substitute variables
if [[ ! -f "CLAUDE.md" ]] || [[ "$FORCE" == "true" ]]; then
    sed \
        -e "s|{{PROJECT_NAME}}|$PROJECT_NAME|g" \
        -e "s|{{STACK}}|$STACK|g" \
        -e "s|{{BUILD_CMD}}|$BUILD_CMD|g" \
        -e "s|{{LINT_CMD}}|$LINT_CMD|g" \
        -e "s|{{TEST_CMD}}|$TEST_CMD|g" \
        -e "s|{{DEV_CMD}}|$DEV_CMD|g" \
        "$SCAFFOLD_DIR/CLAUDE.md" > "CLAUDE.md"
    echo -e "  ${GREEN}CREATE${NC} CLAUDE.md"
else
    echo -e "  ${YELLOW}SKIP${NC} CLAUDE.md (already exists)"
fi

# verification.yml — substitute variables
if [[ ! -f "verification.yml" ]] || [[ "$FORCE" == "true" ]]; then
    sed \
        -e "s|{{DEPS_CHECK}}|$DEPS_CHECK|g" \
        -e "s|{{BUILD_CMD}}|$BUILD_CMD|g" \
        -e "s|{{LINT_CMD}}|$LINT_CMD|g" \
        -e "s|{{TEST_CMD}}|$TEST_CMD|g" \
        -e "s|{{TYPECHECK_CMD}}|$TYPECHECK_CMD|g" \
        "$SCAFFOLD_DIR/verification.yml" > "verification.yml"
    echo -e "  ${GREEN}CREATE${NC} verification.yml"
else
    echo -e "  ${YELLOW}SKIP${NC} verification.yml (already exists)"
fi

# .claude/settings.json — project-level hooks (coexist with plugin hooks)
mkdir -p .claude
if [[ ! -f ".claude/settings.json" ]] || [[ "$FORCE" == "true" ]]; then
    # Build post-edit compile check command based on stack
    POST_EDIT_CHECK=""
    PRE_COMPACT_CHECK=""
    if [[ "$STACK" == Go* ]]; then
        POST_EDIT_CHECK="go vet ./... 2>&1 | head -20"
        PRE_COMPACT_CHECK="go build ./... && $LINT_CMD"
    elif [[ "$STACK" == TypeScript* ]] || [[ "$STACK" == JavaScript* ]]; then
        POST_EDIT_CHECK="npx tsc --noEmit 2>&1 | head -20"
        PRE_COMPACT_CHECK="$BUILD_CMD && $LINT_CMD"
    elif [[ "$STACK" == Python* ]]; then
        POST_EDIT_CHECK="$TYPECHECK_CMD 2>&1 | head -20"
        PRE_COMPACT_CHECK="$LINT_CMD"
    elif [[ "$STACK" == Rust* ]]; then
        POST_EDIT_CHECK="cargo check 2>&1 | head -20"
        PRE_COMPACT_CHECK="cargo build && $LINT_CMD"
    else
        POST_EDIT_CHECK="echo 'no compile check configured'"
        PRE_COMPACT_CHECK="echo 'no build validation configured'"
    fi

    sed \
        -e "s|{{POST_EDIT_CHECK}}|$POST_EDIT_CHECK|g" \
        -e "s|{{PRE_COMPACT_CHECK}}|$PRE_COMPACT_CHECK|g" \
        "$SCAFFOLD_DIR/settings.json" > ".claude/settings.json"
    echo -e "  ${GREEN}CREATE${NC} .claude/settings.json (project-level hooks)"
else
    echo -e "  ${YELLOW}SKIP${NC} .claude/settings.json (already exists)"
fi

copy_file "$SCAFFOLD_DIR/domain-context.md" "domain-context.md" "domain-context.md"
copy_file "$SCAFFOLD_DIR/domain-terms.md" "domain-terms.md" "domain-terms.md"

echo ""

# --- Summary ---
echo -e "${GREEN}ADLC v13 initialized!${NC}"
echo ""
echo "Next steps:"
echo "  1. Edit domain-context.md — describe your business domain"
echo "  2. Edit domain-terms.md — define exact terminology"
echo "  3. Review verification.yml — adjust commands for your project"
echo "  4. Review CLAUDE.md — verify detected stack and commands"
echo "  5. Review .claude/settings.json — verify project-level hooks"
echo "  6. Run: /adlc:build-feature [description] — to start your first feature"
echo ""
echo "Companion plugins (install if not already):"
echo "  /plugin install pr-review-toolkit@claude-plugins-official"
echo "  /plugin install commit-commands@claude-plugins-official"
echo "  /plugin install claude-md-management@claude-plugins-official"
echo "  /plugin install context7@claude-plugins-official"
echo "  /plugin install github@claude-plugins-official"
