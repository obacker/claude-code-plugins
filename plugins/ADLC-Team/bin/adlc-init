#!/bin/bash
# ADLC v7.2 Team — Project Initialization
# Detects stack, generates CLAUDE.md and verification.yml with correct commands.
# Usage: adlc-init [--force]
set -euo pipefail

FORCE=false
[[ "${1:-}" == "--force" ]] && FORCE=true

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCAFFOLD_DIR="$SCRIPT_DIR/../scaffold"
SDLC_DIR=".sdlc"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_create() { echo -e "${GREEN}[create]${NC} $1"; }
log_skip()   { echo -e "${YELLOW}[skip]${NC} $1 (exists, use --force to overwrite)"; }

write_file() {
  local dest="$1" src="$2"
  if [[ -f "$dest" && "$FORCE" != "true" ]]; then
    log_skip "$dest"
    return
  fi
  mkdir -p "$(dirname "$dest")"
  cp "$src" "$dest"
  log_create "$dest"
}

write_template() {
  local dest="$1" src="$2"
  if [[ -f "$dest" && "$FORCE" != "true" ]]; then
    log_skip "$dest"
    return
  fi
  mkdir -p "$(dirname "$dest")"
  sed \
    -e "s|{{PROJECT_NAME}}|$PROJECT_NAME|g" \
    -e "s|{{LANGUAGE}}|$LANGUAGE|g" \
    -e "s|{{FRAMEWORK}}|$FRAMEWORK|g" \
    -e "s|{{DATABASE}}|$DATABASE|g" \
    -e "s|{{BUILD_CMD}}|$BUILD_CMD|g" \
    -e "s|{{LINT_CMD}}|$LINT_CMD|g" \
    -e "s|{{TEST_CMD}}|$TEST_CMD|g" \
    -e "s|{{TEST_ALL_CMD}}|$TEST_ALL_CMD|g" \
    -e "s|{{TYPECHECK_CMD}}|$TYPECHECK_CMD|g" \
    -e "s|{{DEPS_CHECK}}|$DEPS_CHECK|g" \
    -e "s|{{DEV_SERVER_CMD}}|$DEV_SERVER_CMD|g" \
    -e "s|{{COVERAGE_CMD}}|$COVERAGE_CMD|g" \
    "$src" > "$dest"
  log_create "$dest"
}

# ── Stack Detection ──────────────────────────────────────────

PROJECT_NAME=$(basename "$(pwd)")
LANGUAGE="unknown"
FRAMEWORK="unknown"
DATABASE="unknown"
BUILD_CMD="echo 'no build configured'"
LINT_CMD="echo 'no lint configured'"
TEST_CMD="echo 'no test configured'"
TEST_ALL_CMD="echo 'no test configured'"
TYPECHECK_CMD="echo 'no typecheck configured'"
DEPS_CHECK="echo 'no deps check configured'"
DEV_SERVER_CMD="echo 'no dev server configured'"
COVERAGE_CMD="echo 'no coverage configured'"

# Node.js / TypeScript
if [[ -f "package.json" ]]; then
  LANGUAGE="TypeScript"
  DEPS_CHECK="npm ci"

  # Framework detection
  if grep -q '"next"' package.json 2>/dev/null; then
    FRAMEWORK="Next.js"
    BUILD_CMD="npm run build"
    DEV_SERVER_CMD="npm run dev"
  elif grep -q '"nuxt"' package.json 2>/dev/null; then
    FRAMEWORK="Nuxt"
    BUILD_CMD="npm run build"
    DEV_SERVER_CMD="npm run dev"
  elif grep -q '"express"' package.json 2>/dev/null; then
    FRAMEWORK="Express"
    BUILD_CMD="npx tsc"
    DEV_SERVER_CMD="npm run dev"
  else
    FRAMEWORK="Node.js"
    BUILD_CMD="npx tsc --noEmit"
    DEV_SERVER_CMD="npm start"
  fi

  # Test framework
  if grep -q '"vitest"' package.json 2>/dev/null; then
    TEST_CMD="npx vitest run"
    TEST_ALL_CMD="npx vitest run"
    COVERAGE_CMD="npx vitest run --coverage"
  elif grep -q '"jest"' package.json 2>/dev/null; then
    TEST_CMD="npx jest"
    TEST_ALL_CMD="npx jest"
    COVERAGE_CMD="npx jest --coverage"
  fi

  # Linter
  if grep -q '"biome"' package.json 2>/dev/null; then
    LINT_CMD="npx biome check ."
  elif grep -q '"eslint"' package.json 2>/dev/null; then
    LINT_CMD="npx eslint ."
  fi

  # Typecheck
  if [[ -f "tsconfig.json" ]]; then
    TYPECHECK_CMD="npx tsc --noEmit"
  fi

# Go
elif [[ -f "go.mod" ]]; then
  LANGUAGE="Go"
  DEPS_CHECK="go mod download"
  BUILD_CMD="go build ./..."
  TEST_CMD="go test ./..."
  TEST_ALL_CMD="go test -race ./..."
  TYPECHECK_CMD="go vet ./..."
  DEV_SERVER_CMD="go run ."
  COVERAGE_CMD="go test -coverprofile=coverage.out ./..."

  if grep -q "gin-gonic" go.mod 2>/dev/null; then FRAMEWORK="Gin"
  elif grep -q "labstack/echo" go.mod 2>/dev/null; then FRAMEWORK="Echo"
  elif grep -q "gofiber" go.mod 2>/dev/null; then FRAMEWORK="Fiber"
  else FRAMEWORK="Go stdlib"; fi

  if command -v golangci-lint &>/dev/null; then
    LINT_CMD="golangci-lint run"
  else
    LINT_CMD="go vet ./..."
  fi

# Python
elif [[ -f "pyproject.toml" || -f "requirements.txt" ]]; then
  LANGUAGE="Python"
  DEPS_CHECK="pip install -r requirements.txt"
  BUILD_CMD="python -m py_compile *.py"
  TEST_CMD="pytest"
  TEST_ALL_CMD="pytest"
  TYPECHECK_CMD="mypy ."
  DEV_SERVER_CMD="python -m uvicorn app:app --reload"
  COVERAGE_CMD="pytest --cov"

  if grep -q "fastapi" pyproject.toml 2>/dev/null || grep -q "fastapi" requirements.txt 2>/dev/null; then
    FRAMEWORK="FastAPI"
  elif grep -q "django" pyproject.toml 2>/dev/null || grep -q "django" requirements.txt 2>/dev/null; then
    FRAMEWORK="Django"
    DEV_SERVER_CMD="python manage.py runserver"
  elif grep -q "flask" pyproject.toml 2>/dev/null || grep -q "flask" requirements.txt 2>/dev/null; then
    FRAMEWORK="Flask"
    DEV_SERVER_CMD="flask run"
  fi

  if command -v ruff &>/dev/null; then
    LINT_CMD="ruff check ."
  else
    LINT_CMD="flake8"
  fi

# Rust
elif [[ -f "Cargo.toml" ]]; then
  LANGUAGE="Rust"
  FRAMEWORK="Cargo"
  DEPS_CHECK="cargo check"
  BUILD_CMD="cargo build"
  LINT_CMD="cargo clippy"
  TEST_CMD="cargo test"
  TEST_ALL_CMD="cargo test"
  TYPECHECK_CMD="cargo check"
  DEV_SERVER_CMD="cargo run"
  COVERAGE_CMD="cargo tarpaulin"
fi

echo "Detected: $LANGUAGE / $FRAMEWORK"
echo ""

# ── Create directories ───────────────────────────────────────

mkdir -p "$SDLC_DIR"/{specs,tasks,reviews,_active}

# ── Generate files ───────────────────────────────────────────

write_template "CLAUDE.md" "$SCAFFOLD_DIR/CLAUDE.md"
write_template "$SDLC_DIR/verification.yml" "$SCAFFOLD_DIR/verification.yml"
write_file "$SDLC_DIR/domain-context.md" "$SCAFFOLD_DIR/domain-context.md"
write_file "$SDLC_DIR/domain-terms.md" "$SCAFFOLD_DIR/domain-terms.md"

# Create empty knowledge base
if [[ ! -f "$SDLC_DIR/KNOWLEDGE.md" || "$FORCE" == "true" ]]; then
  cat > "$SDLC_DIR/KNOWLEDGE.md" << 'EOF'
# Project Knowledge Base

Append-only log of patterns, gotchas, and build quirks discovered during development.
Read at every session start. Prevents the same mistake twice.

## Entries

EOF
  log_create "$SDLC_DIR/KNOWLEDGE.md"
fi

echo ""
echo "ADLC v7.2 initialized. Next steps:"
echo "  1. Edit CLAUDE.md — fill in project-specific details"
echo "  2. Edit .sdlc/domain-context.md — describe your business domain"
echo "  3. Edit .sdlc/domain-terms.md — add domain terminology"
echo "  4. Review .sdlc/verification.yml — verify detected commands are correct"
echo "  5. Start a session: /smart-start (auto-detects role, or specify BA/DEV/QA)"
